# ============================================================
# Canvas API Configuration
# ============================================================
# Your Canvas LMS domain (e.g., https://canvas.yourschool.edu)
CANVAS_DOMAIN=https://canvas.yourschool.edu

# Your Canvas API access token
# Generate one at: Canvas → Account → Settings → New Access Token
CANVAS_API_TOKEN=your_canvas_api_token_here

# Remember to change this file name to .env after you're done!
